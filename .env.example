# Flask Configuration
SECRET_KEY=your-secret-key-change-in-production
FLASK_ENV=development
FLASK_DEBUG=True

# ICD-11 API Credentials (Get from https://icd.who.int/icdapi)
ICD11_CLIENT_ID=your-client-id-here
ICD11_CLIENT_SECRET=your-client-secret-here

# NAMASTE API (Optional)
NAMASTE_API_KEY=your-namaste-api-key-here

# Google OAuth2 (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database
DATABASE_URL=sqlite:///enhanced_auth.db

# Server Configuration
HOST=0.0.0.0
PORT=8000